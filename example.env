# Copy this file to .env before running the stack.
# All secret values must be stored as files in ../ai-tunnel-secrets and mounted by Docker Compose.

COMPOSE_PROJECT_NAME=ai-tunnel

# Public hostnames
OLLAMA_API_HOSTNAME=ollama-api.example.com
OLLAMA_ADMIN_HOSTNAME=ollama-admin.example.com
OLLAMA_API_PUBLIC_URL=https://ollama-api.example.com/v1
OLLAMA_ADMIN_PUBLIC_URL=https://ollama-admin.example.com
LIBRECHAT_HOSTNAME=librechat.example.com
LIBRECHAT_PUBLIC_URL=https://librechat.example.com

# Image tags
OLLAMA_IMAGE=ollama/ollama:latest
NGINX_IMAGE=nginx:1.29-alpine
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
LIBRECHAT_IMAGE=registry.librechat.ai/danny-avila/librechat:latest
LIBRECHAT_MONGODB_IMAGE=mongo:8.0.20
LIBRECHAT_MEILISEARCH_IMAGE=getmeili/meilisearch:v1.35.1
LIBRECHAT_PGVECTOR_IMAGE=pgvector/pgvector:0.8.0-pg15-trixie
LIBRECHAT_RAG_API_IMAGE=registry.librechat.ai/danny-avila/librechat-rag-api-dev:latest
MCP_MEMORY_IMAGE=ai-tunnel/workspace-memory-bridge:0.1.2
MCP_FILESYSTEM_GATEWAY_IMAGE=ai-tunnel/mcp-filesystem-gateway:2026.1.14
MCP_COMMON_GATEWAY_IMAGE=ai-tunnel/mcp-common-gateway:2026.1.14
PUBMED_MCP_IMAGE=ghcr.io/cyanheads/pubmed-mcp-server@sha256:9da4b9fd16d8f7bce7c4a59f21229b33513f5afcfa07472c715abffbd0ff87f6
MCP_PLAYWRIGHT_IMAGE=mcr.microsoft.com/playwright/mcp@sha256:d238ec7bc98cc4e22df0696d6031dad5b8a4b46781f4f0abaa3bfadeedb43b9a

# Secret file locations
SECRETS_DIR=../ai-tunnel-secrets
CF_TUNNEL_TOKEN_FILE=../ai-tunnel-secrets/cloudflared-token
NGINX_API_TOKEN_FILE=../ai-tunnel-secrets/ollama-api-token
NGINX_BASIC_AUTH_PASSWORD_FILE=../ai-tunnel-secrets/nginx-admin-password
NGINX_BASIC_AUTH_FILE=../ai-tunnel-secrets/nginx-htpasswd
LIBRECHAT_ENV_FILE=../ai-tunnel-secrets/librechat.env
PUBMED_MCP_ENV_FILE=../ai-tunnel-secrets/pubmed-mcp.env
DEEPSEEK_V4_ENV_FILE=../ai-tunnel-secrets/deepseek-v4.env

# Internal service ports
NGINX_LISTEN_PORT=8080
OLLAMA_PORT=11434
CLOUDFLARED_METRICS_PORT=2000
MODEL_ROUTER_PORT=11436
LIBRECHAT_PORT=3080
LIBRECHAT_RAG_PORT=8000
MCP_MEMORY_PORT=39741
MCP_FILESYSTEM_PORT=8001
MCP_PUBMED_GENERAL_PORT=3010
MCP_PUBMED_SYSTEMATIC_PORT=3011
MCP_PUBMED_TRENDS_PORT=3012
MCP_FETCH_PORT=8002
MCP_GIT_PORT=8003
MCP_PLAYWRIGHT_PORT=8005
# Increase this if larger local models need extra time to cold-start in Ollama.
MODEL_ROUTER_TIMEOUT_SECS=300
MODEL_ROUTER_CACHE_TTL_SECS=30
# Comma-separated catalog profiles exposed by model-router. `local-small` is
# what LibreChat fetches for the default selector; tiny chat-only smoke models
# live in `local-smoke` so they do not appear as MCP/tool-calling choices.
MODEL_ROUTER_PROFILE=local-small
MODEL_ROUTER_EXTRA_MODELS=

# Nginx behavior
ENABLE_ADMIN_BASIC_AUTH=true
NGINX_CLIENT_MAX_BODY_SIZE=32m
NGINX_PROXY_READ_TIMEOUT=3600
NGINX_PROXY_SEND_TIMEOUT=3600
NGINX_RATE_LIMIT_RPS=10
NGINX_RATE_LIMIT_BURST=20

# Ollama defaults
# Documented default chat profile: a small local tool-capable Qwen model.
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MODEL_DISPLAY_NAME=Qwen 2.5 3B (Chat + Agent)
# The OpenAI-compatible model id should match the actual Ollama model id unless
# you add a translation layer in front of Ollama.
OLLAMA_MODEL_VSCODE_ID=qwen2.5:3b
# Additional local profiles belong in models/catalog.json, for example
# qwen3:4b, gemma4:e2b, gemma4:e4b, gemma4:26b, gemma4:31b,
# deepseek-v4-flash, and deepseek-v4-pro.
# Use `py -3 scripts/pull_all_models.py --env-file .env --settings-file .vscode/settings.json`
# or the `Stack: Pull All Local Models` task to pull the Ollama catalog.
# DeepSeek V4 is local-only in this stack but is served by compose.deepseek-v4.yaml,
# not by `ollama pull`.
# This host path is the persistence layer for downloaded Ollama models.
OLLAMA_CONTEXT_LENGTH=32768
OLLAMA_MAX_OUTPUT_TOKENS=4096
OLLAMA_MODEL_TOOL_CALLING=true
OLLAMA_MODEL_THINKING=true
OLLAMA_MODEL_STREAMING=true
OLLAMA_AGENT_MODEL=qwen2.5:3b
OLLAMA_AGENT_MODEL_DISPLAY_NAME=Qwen 2.5 3B (Chat + Agent)
OLLAMA_AGENT_MODEL_VSCODE_ID=qwen2.5:3b
OLLAMA_AGENT_CONTEXT_LENGTH=32768
OLLAMA_AGENT_MAX_OUTPUT_TOKENS=4096
OLLAMA_AGENT_MODEL_TOOL_CALLING=true
OLLAMA_AGENT_MODEL_THINKING=true
OLLAMA_AGENT_MODEL_STREAMING=true
# The repo pins one Gemma 4 convenience profile in tasks and workspace settings:
# gemma4:e4b with a 128K context window. Keep other Gemma 4 weight profiles as
# separate workspace catalog entries instead of overloading these default slots.
# Optional tiny local smoke-model for quick chat-only sanity checks. This is not
# the repo's tool-calling proof model; keep using qwen2.5:3b for that check.
OLLAMA_LOCAL_SMOKE_MODEL=qwen2.5:0.5b
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MODELS_PATH=.data/ollama
LIBRECHAT_RAG_EMBEDDINGS_MODEL=nomic-embed-text
WORKSPACE_MEMORY_BRIDGE_REF=1114f5156e8dcdb8be6695ee790a77f95a179c53
MCP_FILESYSTEM_SERVER_VERSION=2026.1.14
MCP_FETCH_SERVER_VERSION=2025.4.7
MCP_GIT_SERVER_VERSION=2026.1.14

# Local DeepSeek V4 overlay. This is not a remote provider; it starts a local
# OpenAI-compatible SGLang server inside Docker and model-router discovers it.
DEEPSEEK_V4_ENABLED=false
DEEPSEEK_V4_IMAGE=lmsysorg/sglang:latest
DEEPSEEK_V4_PORT=30000
DEEPSEEK_V4_MODEL=deepseek-ai/DeepSeek-V4-Flash
DEEPSEEK_V4_MODEL_ALIAS=deepseek-v4-flash
DEEPSEEK_V4_PRO_MODEL=deepseek-ai/DeepSeek-V4-Pro
DEEPSEEK_V4_PRO_MODEL_ALIAS=deepseek-v4-pro
DEEPSEEK_V4_CACHE_PATH=.data/huggingface
DEEPSEEK_V4_TENSOR_PARALLEL_SIZE=1
DEEPSEEK_V4_SHM_SIZE=16gb
DEEPSEEK_V4_EXTRA_ARGS=--trust-remote-code

# Optional path behavior
ENABLE_RAW_OLLAMA_API=true
ENABLE_OPENAI_COMPAT_API=true

# Optional GPU overlay settings.
# NVIDIA overlay: use with docker compose -f compose.yaml -f compose.gpu.yaml ...
# This is the practical Docker path on Windows and Linux when NVIDIA container support is available.
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
OLLAMA_FLASH_ATTENTION=true
# For a single VS Code user, 1 keeps VRAM pressure predictable.
OLLAMA_NUM_PARALLEL=1
# Keep one model resident to avoid reload churn and unexpected VRAM spikes.
OLLAMA_MAX_LOADED_MODELS=1

# AMD ROCm overlay: use with docker compose -f compose.yaml -f compose.amd.yaml ...
# Linux host only. The overlay swaps to the ROCm image and mounts /dev/kfd and /dev/dri.
OLLAMA_IMAGE_AMD=ollama/ollama:rocm
ROCR_VISIBLE_DEVICES=
# Optional ROCm override for unsupported but close GPUs, for example 10.3.0.
HSA_OVERRIDE_GFX_VERSION=

# Vulkan overlay: use with docker compose -f compose.yaml -f compose.vulkan.yaml ...
# Linux host only. This is the experimental path for Intel GPUs and non-ROCm Vulkan devices.
OLLAMA_VULKAN=1
GGML_VK_VISIBLE_DEVICES=
